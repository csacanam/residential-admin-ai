# =============================================================
# CREDENCIALES DEL ADMINISTRADOR
# Copia este archivo como .env y llena los valores reales.
# NUNCA subas el .env al repositorio.
# =============================================================

# --- OpenAI ---
OPENAI_API_KEY=
# Modelo por defecto para tareas normales (actas, mensajes)
OPENAI_DEFAULT_MODEL=gpt-4.1-mini
# Modelo de respaldo para tareas simples (clasificación, validación breve)
OPENAI_FALLBACK_MODEL=gpt-4.1-nano

# --- Kapso / WhatsApp ---
KAPSO_API_KEY=
KAPSO_INSTANCE_ID=
# URL base de la API de Kapso (no cambiar salvo indicación de Kapso)
KAPSO_BASE_URL=https://api.kapso.ai/meta/whatsapp

# --- Google Workspace ---
# Correo del agente (cuenta Google dedicada para este agente — NO la del administrador)
AGENT_EMAIL=
# Correo del administrador al que se envían los documentos generados
ADMIN_EMAIL=
# Ruta al archivo JSON de credenciales OAuth2 de Google
# Instrucciones para obtenerlo: docs/setup-inicial.md → Paso 4
GOOGLE_CREDENTIALS_JSON=./credentials/google-oauth-credentials.json
# Contraseña de aplicación de Gmail (16 caracteres, sin espacios)
# Instrucciones: docs/setup-inicial.md → Paso 4, Parte B
GMAIL_APP_PASSWORD=

# --- Control de costos (en USD) ---
DAILY_USD_BUDGET=1.00
WEEKLY_USD_BUDGET=5.00
MONTHLY_USD_BUDGET=20.00

# --- Localización ---
COUNTRY=CO
TIMEZONE=America/Bogota
CURRENCY=COP

# --- Rutas de trabajo ---
WORKSPACE_DIR=./workspace

# --- Perfil del administrador ---
ADMIN_NAME=
COMPANY_NAME=
